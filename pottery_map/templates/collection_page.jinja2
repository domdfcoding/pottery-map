{% extends "page.jinja2" %}
{% set category_page = category_page | default(False, boolean=True) %}
{% block preamble %}
    <div class="row">
        <div class="col-sm-12 col-md-5">{{ super() }}</div>
        <div class="col-sm-12 col-md-7">
            <form class="items-search mb-sm-2 mt-sm-0 mb-md-0 mt-md-4 mw-50"
                  id="itemsSearchForm"
                  onsubmit="itemsSearch.blur(); return false;">
                <div class="input-group">
                    <div class="form-floating">
                        <input type="search" class="form-control" id="itemsSearch" placeholder="Search">
                        <label for="itemsSearch">Search</label>
                    </div>
                    <button class="btn btn-outline-secondary" type="reset" id="itemsSearchReset">
                        <i class="fa-solid fa-delete-left"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
{% endblock preamble %}

{% block body %}

    <div class="wares gy-2" id="wares">
        <div class="d-flex flex-wrap gap-2 items-container">
            {%- for item in items %}
                <div class="item border p-1 d-flex flex-column"
                     id="{{ item.id }}"
                     data-item-name="{{ item.company.name }} {{ item.design }} {{ item.material }}">
                    <h4>{{ item.design }}</h4>
                    <h5>
                        <a href="{{ root }}companies/{{ make_id(item.company.name) }}.html">{{ item.company.name }}, {{ item.company.factory }}</a>
                    </h5>
                    <div class="container properties">
                        <div class="row">
                            <span>{{ item.description }}</span>
                        </div>
                        {% if item.designer %}
                            <div class="row">
                                <span><i class="fa-solid fa-user"></i> {{ item.designer }}</span>
                            </div>
                        {%- endif %}
                        {% if item.era %}
                            <div class="row">
                                <span><i class="fa-solid fa-calendar-days"></i> {{ item.era }}</span>
                            </div>
                        {%- endif %}
                        {% if item.category and not category_page %}
                            <div class="row">
                                <span><i class="fa-solid fa-chart-diagram"></i> <a href="{{ root }}categories/{{ make_id(normalise_category(item.category) ) }}.html">{{ item.category }}</a></span>
                            </div>
                        {% endif %}
                    </div>

                    {# djlint:off #}
                    {%- if item.has_notes -%}
                        {%- set show_item_notes = True -%}
                        {%- set show_company_notes = True -%}
                        {%- set base_id = item.id -%}
                        {%- set company = item.company %}
                        {% include "notes.jinja2" indent content %}
                    {%- endif %}

                    <div class="mt-auto mx-auto carousel-wrapper ratio ratio-4x3">
                        {% include "carousel.jinja2" indent content %}
                    </div>
                    {# djlint:on #}
                </div>
            {%- endfor %}
        </div>
    </div>
{% endblock body %}

{% block scripts %}
    {{ super() }}
    <script src="https://cdn.jsdelivr.net/gh/domdfcoding/bs5-lightbox@9e1743b/dist/index.bundle.min.js"
            integrity="sha384-pJaIjougtvDzmqvXGZjUt6RKD2XpQOqiBZyaUEEXy5+RSSEZ8iF2yl/JVtrfMGdx"
            crossorigin="anonymous"></script>
    <script type="text/javascript" src="{{ root }}static/js/items_search.js" defer></script>
{% endblock scripts %}
