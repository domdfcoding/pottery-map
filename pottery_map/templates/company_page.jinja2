{% extends "page.jinja2" %}
{% set title = company %}
{% set root = "../" %}
{% set companies_page = True %}
{% block body %}
    <h1>{{ title }}</h1>

    <h2>{{ factory }}</h2>
    {%- if location %}
        {%- set factory_lat = location["latitude"] %}
        {%- set factory_lng = location["longitude"] %}
        <h6>
            <a href='https://www.google.com/maps/place/{{ factory_lat }},{{ factory_lng }}'>View On Map</a>
        </h6>
    {%- endif %}
    {%- if items %}
        <div class="wares gy-2" id="{{ make_id(company) }}-wares">
            <h3>Wares</h3>
            <div class="d-flex flex-wrap gap-3 items-container">
                {%- for item in items %}
                    <div class="item border p-1 d-flex flex-column" id="{{ item['id'] }}">
                        <h4>{{ item['design'] }}</h4>
                        <p>{{ item['material'] }}</p>
                        <p>{{ item['era'] }}</p>
                        {%- for note in item["notes"] %}
                            <code>{{ note }}</code>
                            <br>
                        {%- endfor %}
                        <div class="mt-auto mx-auto pt-1">{% include "carousel.jinja2" indent content %}</div>
                    </div>
                {%- endfor %}
            </div>
        </div>
    {%- endif %}
{% endblock body %}

{% block scripts %}
    {{ super() }}
    <script src="https://cdn.jsdelivr.net/npm/bs5-lightbox@1.8.5/dist/index.bundle.min.js"></script>
{% endblock scripts %}
