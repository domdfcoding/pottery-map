{% extends "collection_page.jinja2" %}
{% set title = company.name %}
{% set root = "../" %}
{% set companies_page = True %}
{% block body %}

    <h2>{{ company.factory }}</h2>
    {%- if company.location %}
        {%- set factory_lat = company.location["latitude"] %}
        {%- set factory_lng = company.location["longitude"] %}
        <h6>
            Show On
            <a href='{{ root }}?zoom=16&lat={{ factory_lat }}&lng={{ factory_lng }}'>
                <i class="fas fa-map"></i>
                Map
            </a>
            or
            <a href='https://www.google.com/maps/place/{{ factory_lat }},{{ factory_lng }}'>
                {% include "sidebar_icons/google_maps_icon.svg" indent content %}
                Google Maps
            </a>
        </h6>

        {# djlint:off #}
        {%- if company.has_notes -%}
            {%- set show_item_notes = False -%}
            {%- set show_company_notes = True -%}
            {%- set base_id = make_id(company.name) %}
            <div class="company-notes mb-2">
                {% include "notes.jinja2" indent content %}
            </div>
        {% endif -%}
        {# djlint:on #}

    {%- endif %}
    {%- if items %}
        <div class="wares gy-2" id="{{ make_id(company.name) }}-wares">
            <h3>Wares</h3>
            <div class="d-flex flex-wrap gap-2 items-container">
                {%- for item in items %}
                    <div class="item border p-1 d-flex flex-column"
                         id="{{ item.id }}"
                         data-item-name="{{ item.design }} {{ item.material }}">
                        <h4>{{ item.design }}</h4>
                        <div class="container properties">
                            <div class="row">
                                <span>{{ item.description }}</span>
                            </div>
                            {% if item.designer %}
                                <div class="row">
                                    <span><i class="fa-solid fa-user"></i> {{ item.designer }}</span>
                                </div>
                            {% endif %}
                            {% if item.era %}
                                <div class="row">
                                    <span><i class="fa-solid fa-calendar-days"></i> {{ item.era }}</span>
                                </div>
                            {% endif %}
                            {% if item.category %}
                                <div class="row">
                                    <span><i class="fa-solid fa-chart-diagram"></i> <a href="{{ root }}categories/{{ make_id(normalise_category(item.category) ) }}.html">{{ item.category }}</a></span>
                                </div>
                            {% endif %}
                        </div>

                        {# djlint:off #}
                        {%- if item.has_notes -%}
                            {%- set show_item_notes = True -%}
                            {%- set show_company_notes = False -%}
                            {%- set base_id = item.id -%}
                            {% include "notes.jinja2" indent content %}
                        {%- endif %}

                        <div class="mt-auto mx-auto carousel-wrapper ratio ratio-4x3">
                            {% include "carousel.jinja2" indent content %}
                        </div>
                        {# djlint:on #}
                    </div>
                {%- endfor %}
            </div>
        </div>
    {%- endif %}
{% endblock body %}

{% block breadcrumbs %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ root }}">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ root }}companies">Companies</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">{{ title }}</li>
        </ol>
    </nav>
{% endblock breadcrumbs %}
