<div class="accordion row notes" id="{{ base_id }}-notes">
    <div class="accordion-item">
        <h2 class="accordion-header" id="{{ base_id }}-note">
            <button class="accordion-button collapsed"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#{{ base_id }}-collapse"
                    aria-expanded="false"
                    aria-controls="{{ base_id }}-collapse">Notes</button>
        </h2>
        <div id="{{ base_id }}-collapse"
             class="accordion-collapse collapse"
             aria-labelledby="{{ base_id }}-note"
             data-bs-parent="#{{ base_id }}-notes">

            <div class="accordion-body">
                {% set show_item_notes = show_item_notes and (item.notes or item.links) -%}
                {% set show_company_notes = show_company_notes and (company.notes or company.links) -%}

                {%- if show_item_notes %}
                    {%- set show_other_notes = show_company_notes %}
                    {%- set item_or_company = item %}
                    {%- set notes_section_title = "This Item" %}
                    {%- include "notes_section.macro.jinja2" indent content -%}
                {%- endif %}

                {%- if show_company_notes %}
                    {%- set show_other_notes = show_item_notes %}
                    {%- set item_or_company = company %}
                    {%- set notes_section_title = "Company" %}
                    {%- include "notes_section.macro.jinja2" indent content -%}
                {%- endif %}
            </div>
        </div>
    </div>
</div>
