{% extends "page.jinja2" %}
{% set title = company %}
{% set root = "../" %}
{% set companies_page = True %}
{% block body %}
    <h1>{{ title }}</h1>

    <h2>{{ factory }}</h2>
    {%- if location %}
        {%- set factory_lat = location["latitude"] %}
        {%- set factory_lng = location["longitude"] %}
        <h6>
            <a href='https://www.google.com/maps/place/{{ factory_lat }},{{ factory_lng }}'>View On Map</a>
        </h6>
    {%- endif %}
    {%- if items %}
        <div class="wares gy-2" id={{ make_id(company) }}-wares>
            <h3>Wares</h3>
            <div class="d-flex flex-wrap gap-3 items-container">
                {%- for item in items %}
                    <div class="item border p-1" id={{ item['id'] }}>
                        <h4>{{ item['design'] }}</h4>
                        <p>{{ item['material'] }}</p>
                        <p>{{ item['era'] }}</p>
                        {%- for note in item["notes"] %}
                            <code>{{ note }}</code>
                            <br>
                        {%- endfor %}
                        <div id="{{ item['id'] }}_carousel" class="carousel slide">
                            <div class="carousel-inner">
                                {%- for idx, photo_url in enumerate(item['photo_urls']) %}
                                    <div class="carousel-item{% if idx == 0 %} active{% endif %}">
                                        <img src="{{ photo_url }}"
                                             class="d-block w-100"
                                             alt="Image {{ idx + 1 }} of the {{ item['design'] }} pottery" />
                                    </div>
                                {%- endfor %}
                            </div>
                            <button class="carousel-control-prev"
                                    type="button"
                                    data-bs-target="#{{ item['id'] }}_carousel"
                                    data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next"
                                    type="button"
                                    data-bs-target="#{{ item['id'] }}_carousel"
                                    data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>

                            <div class="carousel-indicators">
                                {%- for idx, photo_url in enumerate(item['photo_urls']) %}
                                    <button {% if idx == 0 %}class="active" aria-current="true"{% endif %}
                                            data-bs-target="#{{ item['id'] }}_carousel"
                                            role="button"
                                            data-bs-slide-to="{{ idx }}"
                                            aria-label="Slide {{ idx + 1 }}">
                                        <img class="d-block w-100" src="{{ photo_url }}" />
                                    </button>
                                {%- endfor %}
                            </div>
                        </div>
                    </div>
                {%- endfor %}
            </div>
        </div>
    {%- endif %}
{% endblock body %}
