{% extends "page.jinja2" %}
{% set title = "Items" %}
{% set root = "./" %}
{% block body %}
    <h1>{{ title }}</h1>

    <div class="wares gy-2" id="wares">
        <div class="d-flex flex-wrap gap-3 items-container">
            {%- for item in items %}
                <div class="item border p-1 d-flex flex-column" id="{{ item['id'] }}">
                    <h4>{{ item['design'] }}</h4>
                    <h5>
                        <a href="{{ root }}companies/{{ make_id(item["company"]) }}.html">{{ item["company"] }}, {{ item["factory"] }}</a>
                    </h5>
                    <div class="container properties">
                        <div class="row">
                            <span>{{ item['material'] }} {{ item['type'] }}</span>
                        </div>
                        {% if item['designer'] %}
                            <div class="row">
                                <span><i class="fa-solid fa-user"></i> {{ item['designer'] }}</span>
                            </div>
                        {% endif %}
                        {% if item['era'] %}
                            <div class="row">
                                <span><i class="fa-solid fa-calendar-days"></i> {{ item['era'] }}</span>
                            </div>
                        {% endif %}
                    </div>

                    {% if item['notes'] %}
                        <div class="accordion row notes" id="{{ item['id'] }}-notes">
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="{{ item['id'] }}-note">
                                    <button class="accordion-button collapsed"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#{{ item['id'] }}-collapse"
                                            aria-expanded="false"
                                            aria-controls="{{ item['id'] }}-collapse">Notes</button>
                                </h2>
                                <div id="{{ item['id'] }}-collapse"
                                     class="accordion-collapse collapse"
                                     aria-labelledby="{{ item['id'] }}-note"
                                     data-bs-parent="#{{ item['id'] }}-notes">

                                    <div class="accordion-body">
                                        {%- for note in item["notes"] %}
                                            <code>{{ note }}</code>
                                            <br>
                                        {%- endfor %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    {# djlint:off #}
                        <div class="mt-auto mx-auto pt-1">
                            {% include "carousel.jinja2" indent content %}
                        </div>
                    {# djlint:on #}
                </div>
            {%- endfor %}
        </div>
    </div>
{% endblock body %}

{% block scripts %}
    {{ super() }}
    <script src="https://cdn.jsdelivr.net/npm/bs5-lightbox@1.8.5/dist/index.bundle.min.js"></script>
{% endblock scripts %}

{% block extrahead %}
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.2.0/css/all.min.css" />
{% endblock extrahead %}
