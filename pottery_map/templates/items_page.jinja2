{% extends "page.jinja2" %}
{% set title = "Items" %}
{% set root = "./" %}
{% block body %}
    <h1>{{ title }}</h1>

    <div class="wares gy-2" id="wares">
        <div class="d-flex flex-wrap gap-3 items-container">
            {%- for item in items %}
                <div class="item border p-1" id="{{ item['id'] }}">
                    <h3>{{ item['design'] }}</h3>
                    <h4>
                        <a href="{{ root }}companies/{{ make_id(item["company"]) }}.html">{{ item["company"] }}, {{ item["factory"] }}</a>
                    </h4>
                    <p>{{ item['material'] }}</p>
                    <p>{{ item['era'] }}</p>
                    {%- for note in item["notes"] %}
                        <code>{{ note }}</code>
                        <br>
                    {%- endfor %}
                    <div id="{{ item['id'] }}_carousel" class="carousel slide">
                        <div class="carousel-inner">
                            {%- for idx, photo_url in enumerate(item['photo_urls']) %}
                                <div class="carousel-item{% if idx == 0 %} active{% endif %}">
                                    {# TODO: force lightbox to match image size or always be 4:3 #}
                                    <img src="{{ photo_url }}"
                                         class="d-block w-100"
                                         alt="Image {{ idx + 1 }} of the {{ item['design'] }} pottery"
                                         data-toggle="lightbox"
                                         data-remote="{{ photo_url }}"
                                         data-size="lg" />
                                </div>
                            {%- endfor %}
                        </div>
                        <button class="carousel-control-prev"
                                type="button"
                                data-bs-target="#{{ item['id'] }}_carousel"
                                data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next"
                                type="button"
                                data-bs-target="#{{ item['id'] }}_carousel"
                                data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>

                        <div class="carousel-indicators">
                            {%- for idx, photo_url in enumerate(item['photo_urls']) %}
                                <button {% if idx == 0 %}class="active" aria-current="true"{% endif %}
                                        data-bs-target="#{{ item['id'] }}_carousel"
                                        role="button"
                                        data-bs-slide-to="{{ idx }}"
                                        aria-label="Slide {{ idx + 1 }}">
                                    <img class="d-block w-100" src="{{ photo_url }}" />
                                </button>
                            {%- endfor %}
                        </div>
                    </div>
                </div>
            {%- endfor %}
        </div>
    </div>
{% endblock body %}

{% block scripts %}
    {{ super() }}
    <script src="https://cdn.jsdelivr.net/npm/bs5-lightbox@1.8.5/dist/index.bundle.min.js"></script>
{% endblock scripts %}
